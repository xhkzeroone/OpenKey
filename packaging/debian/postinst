#!/bin/sh
set -e

if command -v gtk-update-icon-cache >/dev/null 2>&1; then
  gtk-update-icon-cache -f -t /usr/share/icons/hicolor >/dev/null 2>&1 || true
fi

if command -v setcap >/dev/null 2>&1 && [ -x /usr/libexec/openkey-nonpreedit-server ]; then
  setcap cap_sys_nice+ep /usr/libexec/openkey-nonpreedit-server >/dev/null 2>&1 || true
fi

exit 0
